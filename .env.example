# CWD 评论 API base URL（自托管 Worker，不要末尾斜杠）
PUBLIC_CWD_API_BASE_URL=https://blog.kiwi.moe/api/cwd
PUBLIC_CWD_SITE_ID=kiwi

# Notion 同步凭据（仅本地/CI 使用，绝不入库；Cloudflare Pages 用加密变量）
# 内部集成 token（read content 权限），形如 ntn_xxx
NOTION_TOKEN=
# Notion data source ID（博客数据库），32 位 hex UUID，无连字符或带连字符均可
NOTION_DATA_SOURCE_ID=