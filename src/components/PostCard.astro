---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../i18n/ui';
import { localePath, useTranslations } from '../i18n/utils';
import { postSlug } from '../lib/posts';
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
	post: CollectionEntry<'blog'>;
	lang: Lang;
	featured?: boolean;
	style?: string;
}

const { post, lang, featured = false, style } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const t = useTranslations(lang);
const href = localePath(`/blog/${postSlug(post)}`, lang);
---

<article class:list={['post-card', { 'post-card--featured': featured }]} style={style}>
	<a class="post-card__link" href={href}>
		<div class="post-card__meta">
			<FormattedDate date={pubDate} lang={lang} />
			{featured && <span class="post-card__badge">{t('featured')}</span>}
		</div>
		<h3 class="post-card__title">{title}</h3>
		<p class="post-card__desc">{description}</p>
	</a>
	<TagList tags={tags} lang={lang} />
</article>

<style>
	.post-card {
		position: relative;
		padding: 1.35rem 0 1.5rem;
		border-top: 1px solid var(--line);
		animation: rise var(--duration) var(--ease-out) both;
	}

	.post-card--featured {
		padding: 1.75rem 0 1.85rem;
	}

	.post-card__link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.post-card__meta {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		margin-bottom: 0.55rem;
		font-size: 0.86rem;
		line-height: 1;
		color: var(--ink-faint);
		font-variant-numeric: tabular-nums;
	}

	.post-card__meta :global(time) {
		display: inline-flex;
		align-items: center;
		height: 1.5rem;
		line-height: 1;
	}

	.post-card__badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 1.5rem;
		padding: 0 0.4rem;
		box-sizing: border-box;
		font-size: 0.72rem;
		line-height: 1;
		letter-spacing: 0.12em;
		color: var(--accent-ink);
		border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
	}

	.post-card__title {
		margin: 0 0 0.45rem;
		font-size: 1.35rem;
		transition: color var(--duration) var(--ease-out);
	}

	.post-card--featured .post-card__title {
		font-size: clamp(1.6rem, 1.3rem + 1.2vw, 2.15rem);
	}

	.post-card__desc {
		margin: 0 0 0.85rem;
		color: var(--ink-muted);
		font-size: 0.98rem;
		line-height: 1.7;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card__link:hover .post-card__title {
		color: var(--accent-ink);
	}

	.post-card::before {
		content: '';
		position: absolute;
		left: 0;
		top: -1px;
		width: 3.5rem;
		height: 2px;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform var(--duration) var(--ease-out);
	}

	.post-card:hover::before {
		transform: scaleX(1);
	}
</style>
