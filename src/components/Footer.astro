---
import { SITE_AUTHOR, SITE_TITLE, SITE_TITLE_EN, SOCIAL } from '../consts';
import type { Lang } from '../i18n/ui';
import { localePath, useTranslations } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-footer__inner container">
		<div class="site-footer__brand">
			<p class="site-footer__name">{SITE_TITLE}</p>
			<p class="site-footer__en">{SITE_TITLE_EN}</p>
			<p class="site-footer__tagline">{t('footer.tagline')}</p>
		</div>

		<div class="site-footer__links">
			<a href={localePath('/blog', lang)}>{t('nav.blog')}</a>
			<a href={localePath('/tags', lang)}>{t('nav.tags')}</a>
			<a href={localePath('/about', lang)}>{t('nav.about')}</a>
			<a href={SOCIAL.rss}>{t('nav.rss')}</a>
			<a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>

		<p class="site-footer__copy">© {year} {SITE_AUTHOR}. {t('footer.copy')}</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--line);
		padding: var(--space-xl) 0 var(--space-lg);
		margin-top: auto;
	}

	.site-footer__inner {
		display: grid;
		gap: var(--space-lg);
	}

	.site-footer__name {
		font-family: var(--font-display);
		font-size: 1.65rem;
		letter-spacing: 0.14em;
		margin: 0;
	}

	.site-footer__en {
		margin: 0.2rem 0 0;
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--ink-faint);
	}

	.site-footer__tagline {
		margin: 0.75rem 0 0;
		color: var(--ink-muted);
		max-width: 22rem;
	}

	.site-footer__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem 1.35rem;
	}

	.site-footer__links a {
		text-decoration: none;
		color: var(--ink-muted);
		letter-spacing: 0.04em;
	}

	.site-footer__links a:hover {
		color: var(--accent);
	}

	.site-footer__copy {
		margin: 0;
		padding-top: var(--space-md);
		border-top: 1px solid var(--line);
		font-size: 0.88rem;
		color: var(--ink-faint);
	}
</style>
