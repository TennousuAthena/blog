---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<button
	type="button"
	class="theme-toggle"
	data-theme-toggle
	aria-label={t('theme.toDark')}
>
	<span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
		<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
			<circle cx="12" cy="12" r="4"></circle>
			<path d="M12 2v2.2M12 19.8V22M4.2 12H2M22 12h-2.2M5.6 5.6l1.6 1.6M16.8 16.8l1.6 1.6M18.4 5.6l-1.6 1.6M7.2 16.8l-1.6 1.6"></path>
		</svg>
	</span>
	<span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
		<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
			<path d="M20.5 14.2A8.2 8.2 0 0 1 9.8 3.5 8.5 8.5 0 1 0 20.5 14.2Z"></path>
		</svg>
	</span>
</button>

<script>
	const labels = {
		zh: { toLight: '切换到日间模式', toDark: '切换到夜间模式' },
		en: { toLight: 'Switch to light mode', toDark: 'Switch to dark mode' },
	} as const;

	function currentLang() {
		return document.documentElement.lang?.startsWith('zh') ? 'zh' : 'en';
	}

	function syncToggle(theme: string) {
		const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
		if (!btn) return;
		const lang = currentLang();
		btn.setAttribute('aria-label', theme === 'dark' ? labels[lang].toLight : labels[lang].toDark);
		btn.dataset.theme = theme;
	}

	function applyTheme(theme: 'light' | 'dark', persist = true) {
		document.documentElement.setAttribute('data-theme', theme);
		const meta = document.querySelector('meta[name="theme-color"]');
		if (meta) {
			meta.setAttribute('content', theme === 'dark' ? '#12151a' : '#eef1f5');
		}
		if (persist) localStorage.setItem('mojian-theme', theme);
		syncToggle(theme);
		window.dispatchEvent(new CustomEvent('mojian:theme', { detail: { theme } }));
	}

	document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const next =
				document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
			applyTheme(next);
		});
	});

	syncToggle(document.documentElement.getAttribute('data-theme') || 'light');
</script>

<style>
	.theme-toggle {
		display: inline-grid;
		place-items: center;
		width: 2.35rem;
		height: 2.35rem;
		border: 1px solid var(--line-strong);
		background: var(--surface);
		color: var(--ink-muted);
		border-radius: var(--radius);
		cursor: pointer;
		padding: 0;
		transition:
			color var(--duration) var(--ease-out),
			border-color var(--duration) var(--ease-out),
			background var(--duration) var(--ease-out);
	}

	.theme-toggle:hover {
		color: var(--ink);
		border-color: var(--ink-muted);
	}

	.theme-toggle__icon {
		grid-area: 1 / 1;
		display: grid;
		place-items: center;
		transition: opacity 200ms var(--ease-out), transform 200ms var(--ease-out);
	}

	.theme-toggle__icon--moon {
		opacity: 0;
		transform: rotate(-20deg) scale(0.7);
	}

	:global([data-theme='dark']) .theme-toggle__icon--sun {
		opacity: 0;
		transform: rotate(20deg) scale(0.7);
	}

	:global([data-theme='dark']) .theme-toggle__icon--moon {
		opacity: 1;
		transform: none;
	}
</style>
