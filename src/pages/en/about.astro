---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, SITE_URL } from '../../consts';
import { useTranslations } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<BaseLayout title={t('about.title')} description={SITE.en.description} lang={lang}>
	<section class="about container--narrow">
		<header class="about__header">
			<p class="about__eyebrow anim-rise">{t('about.eyebrow')}</p>
			<h1 class="anim-rise" style="animation-delay: 60ms">{t('about.title')}</h1>
			<p class="about__lede anim-rise" style="animation-delay: 120ms">{t('about.lede')}</p>
			<span class="about__rule anim-fade" aria-hidden="true"></span>
		</header>

		<div class="prose about__body anim-rise" style="animation-delay: 180ms">
			<p>
				Kiwi's web log is my personal blog at
				<a href={SITE_URL}>{SITE_URL.replace(/^https?:\/\//, '')}</a>.
				It is not a portfolio and not a tutorial site — more like an open notebook for notes,
				records, and the slower work of reflection.
			</p>
			<p>
				I use it to capture what I am thinking, what I have tried, and the fragments that are hard
				to name in the moment but worth keeping. Some posts stay short; others grow. Completeness
				is optional; honesty is not.
			</p>
			<h2>On writing</h2>
			<p>
				The substance is written by me. Much of the sentence-level polishing is done with generative
				AI — it helps clarify the wording; the ideas and choices remain mine.
			</p>
			<h2>What you will find</h2>
			<ul>
				<li>Notes — immediate thoughts, drafts, and field marks</li>
				<li>Records — attempts, mistakes, and processes worth revisiting</li>
				<li>Reflection — conclusions and methods that still feel worth keeping</li>
			</ul>
			<p>
				If a piece helps you too, welcome. If it only helps me settle a thought, that is enough.
			</p>
		</div>
	</section>
</BaseLayout>

<style>
	.about {
		padding-top: var(--space-xl);
		margin-inline: auto;
	}

	.about__eyebrow {
		margin: 0 0 0.65rem;
		font-family: var(--font-code);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-ink);
	}

	.about__lede {
		margin: 0;
		color: var(--ink-muted);
		font-size: 1.08rem;
	}

	.about__rule {
		display: block;
		width: 3.5rem;
		height: 2px;
		margin: 1.5rem 0 2rem;
		background: var(--accent);
		transform-origin: left;
		animation: draw-line var(--duration) var(--ease-out) 260ms both;
	}
</style>
