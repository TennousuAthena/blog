---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../consts';
import { localePath, useTranslations } from '../../../i18n/utils';
import { postsByLang } from '../../../lib/posts';

const lang = 'en' as const;
const t = useTranslations(lang);
const posts = postsByLang(await getCollection('blog'), lang);
const tagMap = new Map<string, number>();

for (const post of posts) {
	for (const tag of post.data.tags) {
		tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
	}
}

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'en'));
---

<BaseLayout title={t('tags.title')} description={SITE.en.description} lang={lang}>
	<section class="page container">
		<header class="page__header">
			<p class="page__eyebrow anim-rise">{t('tags.eyebrow')}</p>
			<h1 class="anim-rise" style="animation-delay: 60ms">{t('tags.title')}</h1>
			<p class="page__lede anim-rise" style="animation-delay: 120ms">{t('tags.lede')}</p>
		</header>

		<ul class="tag-cloud">
			{
				tags.map(([tag, count], i) => (
					<li class="anim-rise" style={`animation-delay: ${Math.min(i * 40, 320)}ms`}>
						<a href={localePath(`/tags/${encodeURIComponent(tag)}`, lang)}>
							<span class="tag-cloud__name">#{tag}</span>
							<span class="tag-cloud__count">{count}</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>

<style>
	.page {
		padding-top: var(--space-xl);
	}

	.page__header {
		max-width: 36rem;
		margin-bottom: var(--space-lg);
	}

	.page__eyebrow {
		margin: 0 0 0.65rem;
		font-family: var(--font-code);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-ink);
	}

	.page__lede {
		margin: 0;
		color: var(--ink-muted);
	}

	.tag-cloud {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
		gap: 0.75rem;
	}

	.tag-cloud li,
	.tag-cloud li + li {
		margin: 0;
		padding: 0;
	}

	.tag-cloud a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.95rem 1rem;
		text-decoration: none;
		color: var(--ink);
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: 4px;
		transition:
			border-color var(--duration) var(--ease-out),
			transform var(--duration) var(--ease-out),
			background var(--duration) var(--ease-out);
	}

	.tag-cloud a:hover {
		border-color: color-mix(in srgb, var(--accent) 45%, transparent);
		background: var(--surface-elevated);
		transform: translateY(-2px);
	}

	.tag-cloud__name {
		letter-spacing: 0.02em;
	}

	.tag-cloud__count {
		font-family: var(--font-code);
		font-size: 0.8rem;
		color: var(--ink-faint);
	}
</style>
