---
import { getCollection } from 'astro:content';
import PostCard from '../../../components/PostCard.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../consts';
import { localePath, useTranslations } from '../../../i18n/utils';
import { postsByLang } from '../../../lib/posts';

const lang = 'en' as const;

export async function getStaticPaths() {
	const posts = postsByLang(await getCollection('blog'), 'en');
	const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
	return tags.map((tag) => ({
		params: { tag },
		props: { tag },
	}));
}

const { tag } = Astro.props;
const t = useTranslations(lang);
const posts = postsByLang(await getCollection('blog'), lang).filter((post) =>
	post.data.tags.includes(tag),
);
---

<BaseLayout title={`#${tag}`} description={SITE.en.description} lang={lang}>
	<section class="page container">
		<header class="page__header">
			<p class="page__eyebrow anim-rise">
				<a href={localePath('/tags', lang)}>{t('tags.all')}</a>
			</p>
			<h1 class="anim-rise" style="animation-delay: 60ms">#{tag}</h1>
			<p class="page__lede anim-rise" style="animation-delay: 120ms">
				{t('tags.count', { n: posts.length })}
			</p>
		</header>

		<div class="page__list">
			{
				posts.map((post, i) => (
					<PostCard post={post} lang={lang} style={`animation-delay: ${Math.min(i * 50, 300)}ms`} />
				))
			}
		</div>
	</section>
</BaseLayout>

<style>
	.page {
		padding-top: var(--space-xl);
	}

	.page__header {
		max-width: 36rem;
		margin-bottom: var(--space-lg);
	}

	.page__eyebrow {
		margin: 0 0 0.65rem;
		font-family: var(--font-code);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
	}

	.page__eyebrow a {
		text-decoration: none;
		color: var(--accent-ink);
	}

	.page__lede {
		margin: 0;
		color: var(--ink-muted);
	}

	.page__list {
		border-bottom: 1px solid var(--line);
	}
</style>
