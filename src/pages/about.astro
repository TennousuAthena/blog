---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SITE_URL } from '../consts';
import { useTranslations } from '../i18n/utils';

const lang = 'zh' as const;
const t = useTranslations(lang);
---

<BaseLayout title={t('about.title')} description={SITE.zh.description} lang={lang}>
	<section class="about container--narrow">
		<header class="about__header">
			<p class="about__eyebrow anim-rise">{t('about.eyebrow')}</p>
			<h1 class="anim-rise" style="animation-delay: 60ms">{t('about.title')}</h1>
			<p class="about__lede anim-rise" style="animation-delay: 120ms">{t('about.lede')}</p>
			<span class="about__rule anim-fade" aria-hidden="true"></span>
		</header>

		<div class="prose about__body anim-rise" style="animation-delay: 180ms">
			<p>
				「奇异果网络日志」是我的个人博客，域名
				<a href={SITE_URL}>{SITE_URL.replace(/^https?:\/\//, '')}</a>
				。我会将探索路上遇见的想法、问题与结论随手记下来，再在回望时慢慢沉淀。
			</p>
			<p>
				
			</p>
			<h2>关于写作</h2>
			<p>
				这里的内容核心由我自己编写。句子上的打磨与整理，大多会借助生成式人工智能润色。
				我会尽最大努力避免事实性错误。
			</p>
			<h2>你会读到什么</h2>
			<ul>
				<li>随记：即时的想法、草稿与现场感</li>
				<li>记录：做过的事、踩过的坑、可复盘的过程</li>
				<li>沉淀：整理之后仍想留下的结论与方法</li>
			</ul>
		</div>
	</section>
</BaseLayout>

<style>
	.about {
		padding-top: var(--space-xl);
		margin-inline: auto;
	}

	.about__eyebrow {
		margin: 0 0 0.65rem;
		font-family: var(--font-code);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-ink);
	}

	.about__lede {
		margin: 0;
		color: var(--ink-muted);
		font-size: 1.08rem;
	}

	.about__rule {
		display: block;
		width: 3.5rem;
		height: 2px;
		margin: 1.5rem 0 2rem;
		background: var(--accent);
		transform-origin: left;
		animation: draw-line var(--duration) var(--ease-out) 260ms both;
	}
</style>
