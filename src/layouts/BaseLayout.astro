---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MermaidTheme from '../components/MermaidTheme.astro';
import type { ImageMetadata } from 'astro';
import type { Lang } from '../i18n/ui';
import { htmlLang, useTranslations } from '../i18n/utils';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	lang?: Lang;
	markdownUrl?: string;
}

const { title, description, image, lang = 'zh', markdownUrl } = Astro.props;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={htmlLang(lang)}>
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			lang={lang}
			markdownUrl={markdownUrl}
		/>
	</head>
	<body>
		<a class="skip-link" href="#main">{t('skip')}</a>
		<Header lang={lang} />
		<main id="main">
			<slot />
		</main>
		<Footer lang={lang} />
		<MermaidTheme />
	</body>
</html>

<style is:global>
	/* 平时完全不可见；仅 Tab 聚焦时浮出，供键盘用户跳过导航 */
	.skip-link {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
		color: var(--paper);
		background: var(--ink);
		text-decoration: none;
		border-radius: var(--radius);
	}

	.skip-link:focus {
		position: fixed;
		top: 1rem;
		left: 1rem;
		z-index: 1000;
		width: auto;
		height: auto;
		margin: 0;
		padding: 0.5rem 0.85rem;
		overflow: visible;
		clip: auto;
		white-space: normal;
	}

	main {
		min-height: 60vh;
		padding-bottom: var(--space-2xl);
	}
</style>
